{% extends 'base.html.twig' %}

{% block title %}News Admin Login{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/vendor/bootswatch-flatly.min.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/admin-theme-overrides.css') }}">
{% endblock %}

{% block body %}
    <div class="login-page-wrapper d-flex align-items-center justify-content-center p-3">
        <main class="card shadow-sm" style="max-width: 440px; width: 100%;">
            <div class="card-body p-4 p-md-5">
                <h1 class="h3 mb-1">News Admin</h1>
                <p class="text-muted mb-4">Zaloguj się do panelu</p>

                {% if error %}
                    <div class="alert alert-danger" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="email"
                            id="email"
                            class="form-control"
                            autocomplete="email"
                            required
                            autofocus
                        >
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label">Hasło</label>
                        <input
                            type="password"
                            name="password"
                            id="password"
                            class="form-control"
                            autocomplete="current-password"
                            required
                        >
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn btn-primary w-100">Zaloguj</button>
                </form>
            </div>
        </main>
    </div>
{% endblock %}
