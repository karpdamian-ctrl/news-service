<header class="topbar">
    <div class="container py-3 d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-between">
        <a href="{{ path('app_home') }}" class="brand fs-3">
            {{ header.site_name }}<span class="brand-dot">.</span>
        </a>
        <nav class="d-flex gap-3">
            {% for item in header.menu %}
                <a href="{{ item.href }}" class="top-nav-link">{{ item.label }}</a>
            {% endfor %}
        </nav>
    </div>
</header>
