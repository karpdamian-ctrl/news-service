{% extends 'base.html.twig' %}

{% block title %}News Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/styles/vendor/bootswatch-flatly.min.css">
    <link rel="stylesheet" href="/styles/admin-theme-overrides.css">
{% endblock %}

{% block body %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold d-inline-flex align-items-center gap-2" href="{{ path('admin') }}">
                <span aria-hidden="true">📰</span>
                <span>News Admin</span>
            </a>
            <div class="d-flex ms-auto gap-2">
                <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <div class="row">
            <aside class="col-12 col-md-3 col-xl-2 mb-4">
                <div class="list-group shadow-sm">
                    {% for item in menu_items %}
                        <a
                            href="{{ path(item.route) }}"
                            class="list-group-item list-group-item-action {{ item.key == resource_key ? 'active' : '' }}"
                        >
                            {{ item.label }}
                        </a>
                    {% endfor %}
                </div>
            </aside>
            <main class="col-12 col-md-9 col-xl-10">
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ type == 'error' ? 'danger' : type }} mb-3">{{ message }}</div>
                    {% endfor %}
                {% endfor %}
                {% block admin_content %}{% endblock %}
            </main>
        </div>
    </div>
{% endblock %}
